# API Server
PORT=8080
NODE_ENV=development
LOG_LEVEL=debug

# CORS — comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:5173,http://localhost:80

# Local directory scanning — comma-separated allowlist of absolute paths
# LOCAL_SCAN_ALLOWED_ROOTS=/path/to/states,/another/path

# Estimator mapping freshness (days)
ESTIMATOR_MAPPING_STALE_DAYS=30

# Cloud provider scanning feature flags
# ENABLE_AWS_S3_SCAN=true
# ENABLE_AZURE_BLOB_SCAN=true
# ENABLE_GCP_GCS_SCAN=true

# AWS credentials (for S3 scanning)
# AWS_REGION=us-east-1
# AWS_PROFILE=default
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=

# Azure credentials (for Blob storage scanning)
# AZURE_TENANT_ID=
# AZURE_SUBSCRIPTION_ID=

# GCP credentials (for GCS scanning)
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
# CLOUDSDK_CORE_PROJECT=my-project
